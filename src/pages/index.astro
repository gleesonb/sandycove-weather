---
import "../styles/global.css";
import App from "../components/App";
import DarkModeToggle from "../components/DarkModeToggle";
import NotificationToggle from "../components/NotificationToggle";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sandycove Weather</title>
    <meta
      name="description"
      content="Live weather conditions from Sandycove, Dublin, Ireland"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://weather.billgleeson.com" />
    <meta name="theme-color" content="#1a5fa0" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icon-192.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content="Sandycove Weather" />
    <meta
      property="og:description"
      content="Live weather conditions from Sandycove, Dublin, Ireland"
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://weather.billgleeson.com" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Sandycove Weather" />
    <meta
      name="twitter:description"
      content="Live weather conditions from Sandycove, Dublin, Ireland"
    />

    <script is:inline>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen">
    <header class="relative overflow-hidden bg-gradient-to-br from-ocean-600 via-ocean-700 to-ocean-800 dark:from-ocean-900 dark:via-ocean-950 dark:to-gray-950 text-white py-5 px-6 shadow-lg transition-colors duration-300">
      <div class="absolute inset-0 opacity-[0.04] dark:opacity-[0.06]" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22><path d=%22M0 30 Q15 20 30 30 Q45 40 60 30%22 fill=%22none%22 stroke=%22white%22 stroke-width=%221.5%22/></svg>'); background-size: 60px 60px;"></div>
      <div class="relative max-w-4xl mx-auto flex items-center justify-between">
        <div>
          <h1 class="font-display text-2xl font-semibold tracking-tight">Sandycove Weather</h1>
          <p class="text-ocean-200 dark:text-ocean-400 text-sm mt-0.5">Dublin, Ireland &middot; Live from Station IDNLAO16</p>
        </div>
        <div class="flex items-center gap-1">
          <NotificationToggle client:load />
          <DarkModeToggle client:load />
        </div>
      </div>
    </header>
    <main class="max-w-4xl mx-auto px-4 py-8">
      <App client:load />
    </main>
    <footer class="border-t border-ocean-200/30 dark:border-ocean-800/30 text-center text-xs text-ocean-600/60 dark:text-ocean-200/30 py-6 px-4 transition-colors">
      <p>Built by Niall Flynn with Astro + Cloudflare</p>
      <p class="mt-1">Data from Weather Underground &middot; Forecast from Met Eireann</p>
    </footer>
  </body>
</html>
